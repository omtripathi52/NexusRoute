# ============================================
# Databases & Vector Store
# ============================================
# Note: prebuilt knowledge-base vector DB files should remain in git.
# - backend/data/vectordb/ (prebuilt knowledge base, keep tracked)
# - backend/scripts/data/vectordb/ (prebuilt knowledge base, keep tracked)

# Ignore runtime-generated database files
*.db
*.sqlite
*.sqlite3

# Keep prebuilt vector DB artifacts (required project data)
!backend/data/vectordb/**
!backend/scripts/data/vectordb/**

# Ignore database directories in other locations
chroma_db/
backend/chroma_db/

# PostgreSQL
postgres_data/

